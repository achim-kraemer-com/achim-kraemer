<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Visitenkarte Achim Krämer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-purple: #2B2434;
            --accent-beige: #E7D2A5;
            --text-grey: #B9B5B5;
            /* Maße in mm für Präzision */
            --width-total: 91mm;  /* 85 + 3 + 3 */
            --height-total: 61mm; /* 55 + 3 + 3 */
            --width-trim: 85mm;
            --height-trim: 55mm;
            --bleed: 3mm;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f0f0f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
            gap: 50px;
        }

        /* Die Karte selbst */
        .card-container {
            position: relative;
            width: var(--width-total);
            height: var(--height-total);
            background-color: var(--bg-purple);
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            cursor: default;
        }

        /* Hilfslinien zur Visualisierung (im Druck ausblenden) */
        .guides {
            position: absolute;
            top: var(--bleed);
            left: var(--bleed);
            width: var(--width-trim);
            height: var(--height-trim);
            border: 1px dashed rgba(255,255,255,0.1);
            pointer-events: none;
            z-index: 100;
        }

        .label {
            color: #333;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Hintergrund Code-Pattern */
        .code-pattern {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            font-family: monospace;
            font-size: 6px;
            color: rgba(255, 255, 255, 0.06);
            padding: 10mm;
            line-height: 1.2;
            white-space: pre;
            pointer-events: none;
        }

        /* Logo-Stil */
        .logo-circle {
            width: 30mm;
            height: 30mm;
            border: 2px solid var(--accent-beige);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 5mm;
            position: relative;
        }

        .logo-icon {
            color: var(--accent-beige);
            font-size: 14mm;
            font-weight: bold;
        }

        /* Texte */
        .name-front {
            color: var(--accent-beige);
            font-size: 5mm;
            font-weight: 700;
            margin: 0;
        }

        .role-front {
            color: var(--text-grey);
            font-size: 3mm;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-top: 1mm;
        }

        /* Rückseiten Layout */
        .back-content {
            display: flex;
            width: 100%;
            height: 100%;
            padding: calc(var(--bleed) + 5mm);
            align-items: center;
        }

        .left-col {
            flex: 0 0 45%;
            border-right: 1px solid rgba(231, 210, 165, 0.2);
            height: 60%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .right-col {
            flex: 1;
            padding-left: 8mm;
            display: flex;
            flex-direction: column;
            gap: 3mm;
        }

        .contact-item {
            display: flex;
            align-items: center;
            gap: 3mm;
            color: #fff;
            font-size: 2.8mm;
        }

        .contact-icon {
            width: 4mm;
            height: 4mm;
            color: var(--accent-beige);
        }

        .footer-social {
            position: absolute;
            bottom: calc(var(--bleed) + 5mm);
            right: calc(var(--bleed) + 8mm);
            font-size: 2.2mm;
            color: var(--text-grey);
        }

        @media print {
            body { background: none; padding: 0; }
            .label, .guides, .print-btn { display: none; }
            .card-container { box-shadow: none; margin: 0; page-break-after: always; }
        }

        .print-btn {
            position: fixed;
            top: 20px;
            right: 20px;
            background: #2B2434;
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.2s;
            z-index: 1000;
        }
        .print-btn:hover { background: #3f354d; }
    </style>
</head>
<body>

<button class="print-btn" onclick="window.print()">Als PDF speichern / Drucken</button>

<!-- VORDERSEITE -->
<div class="flex flex-col items-center">
    <div class="label">Vorderseite (Branding)</div>
    <div class="card-container">
        <div class="guides"></div>
        <div class="code-pattern">
            const developer = {
            name: "Achim Krämer",
            role: "Software Developer",
            skills: ["React", "Node.js", "Cloud"],
            motto: "Code is Poetry"
            };

            function buildFuture() {
            return developer.skills.map(s => s.improve());
            }
        </div>

        <div class="flex flex-col items-center justify-center h-full">
            <div class="logo-circle">
                <div class="logo-icon">&lt;/&gt;</div>
            </div>
            <h1 class="name-front">Achim Krämer</h1>
            <p class="role-front">Software Developer</p>
        </div>
    </div>
</div>

<!-- RÜCKSEITE -->
<div class="flex flex-col items-center">
    <div class="label">Rückseite (Kontakt)</div>
    <div class="card-container">
        <div class="guides"></div>

        <div class="back-content">
            <div class="left-col">
                <div style="color: var(--accent-beige); font-weight: 700; font-size: 4.5mm;">Achim Krämer</div>
                <div style="color: var(--text-grey); font-size: 2.8mm; margin-top: 1mm;">Software Developer</div>
            </div>

            <div class="right-col">
                <div class="contact-item">
                    <svg class="contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                    01756 2618330
                </div>
                <div class="contact-item">
                    <svg class="contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    kontakt@achim-kraemer.com
                </div>
                <div class="contact-item">
                    <svg class="contact-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                    achim.kraemer.digital
                </div>
            </div>
        </div>

        <div class="footer-social">
            Besuche mich auf: LinkedIn · X · GitHub
        </div>
    </div>
</div>

</body>
</html>
